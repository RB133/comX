# Base URL of the ComX backend API.
# Local: http://localhost:3000   Production: https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:3000

# Socket.IO server URL. Same host as the backend (Socket.IO upgrades http->ws itself).
# Local: http://localhost:3000   Production: https://your-backend.onrender.com
VITE_SOCKET_URL=http://localhost:3000

# LiveKit WebSocket URL for community video calls (optional).
VITE_PUBLIC_LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
