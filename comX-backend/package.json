{
  "name": "comx-backend",
  "version": "1.0.0",
  "description": "ComX backend — Express + Prisma + Socket.IO API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "npm run migrate:deploy && node dist/server.js",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "author": "Rishit Bansal <rishitbansal231@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.21.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie": "^0.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.13.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.6.1",
    "prisma": "^5.21.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
