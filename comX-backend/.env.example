# ─── Core (required) ────────────────────────────────
# Port the API listens on.
PORT=3000

# PostgreSQL connection string.
# Local (docker-compose): postgresql://comx:comx@localhost:5432/comx
DATABASE_URL="postgresql://comx:comx@localhost:5432/comx"

# Long random string used to sign auth cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_secret"

# Comma-separated list of allowed frontend origins (no trailing slash).
# http://localhost:5173 is always allowed automatically.
FRONTEND_URL="http://localhost:5173"

# development | production. Controls secure-cookie behaviour and logging.
NODE_ENV=development

# ─── Cloudinary (optional — enables avatar / cover uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── LiveKit (optional — enables community video calls) ──
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
